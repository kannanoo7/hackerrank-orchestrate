# Support Triage Agent - Environment Configuration
# Copy this file to .env and fill in your API keys (if desired)
# The agent works with or without API keys; without keys, it falls back to heuristics

# Anthropic Claude API (optional - for LLM-powered response generation)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
